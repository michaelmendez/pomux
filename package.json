    "workbox-window": "7.4.1"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@eslint/js": "10.0.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/babel__core": "7.20.5",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
